{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "module": "CommonJS",
    "paths": {
      "@actions/*": ["./helpers/actions/*"],
      "@assertions/*": ["./helpers/assertions/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@pages": ["./page-objects/pages/index.ts"],
      "@modals": ["./page-objects/modals/index.ts"],
      "@interface/*": ["./interface/*"],
      "@helpers/*": ["./helpers/*"],
      "@test-data/*": ["./test-data/*"]
    },
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./test-results",
    "./playwright-report",
  ]
}