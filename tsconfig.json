{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "module": "CommonJS",
    "paths": {
      "@actions/*": ["helpers/actions/*"],
      "@assertions/*": ["helpers/assertions/*"],
      "@fixtures/*": ["fixtures/*"],
      "@pages/*": ["page-objects/pages/*"],
      "@modals/*": ["page-objects/modals/*"],
      "@components/*": ["page-objects/components/*"]
    },
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./test-results",
    "./playwright-report",
  ]
}